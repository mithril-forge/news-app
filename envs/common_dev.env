POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CONTAINER_API_URL=http://backend:8000
FRONTEND_URL=http://localhost:3000
LOCAL_ARCHIVE_FOLDER=/tmp/archive_folder

AI_PROVIDER=deepinfra
GEMINI_API_KEY=your_api_key
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_GLOBAL_DAILY_LIMIT=100
DEEPINFRA_API_KEY=your_deepinfra_api_key
DEEPINFRA_MODEL_NAME=deepseek-ai/DeepSeek-V3.2-Exp
DEEPINFRA_GLOBAL_DAILY_LIMIT=100

SCRAP_MAX_ARTICLES_PER_SITE=50
INPUT_NEWS_HOURS=72
INPUT_NEWS_LIMIT=20
SCRAP_ARTICLES_CRON=00 06,14,22 * * *
CONNECTING_PARSED_NEWS_LIMIT=24
CONNECTING_INPUT_NEWS_LIMIT=72
DAILY_PICK_GENERATION_CRON=00 06 * * *
REDIS_URL=redis://redis:6379
USE_MOCKED_AI=false
